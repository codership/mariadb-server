connection node_2;
connection node_1;
CREATE TABLE t1 (f1 INTEGER PRIMARY KEY DEFAULT 0, f2 char(12));
CREATE TABLE t3 (f1 INTEGER PRIMARY KEY DEFAULT 0, f2 char(12));
START TRANSACTION;
INSERT INTO t3 (f1, f2) VALUES (1, 'a');
connection node_2;
SET GLOBAL wsrep_applier_retry_count = 2;
SET GLOBAL debug_dbug = "+d,innodb_insert_fail:o,/dev/null";
CALL mtr.add_suppression("WSREP: Event .* Write_rows_v1 apply failed:");
connection node_1;
INSERT INTO t3 (f1, f2) VALUES (2, 'b');
INSERT INTO t1 (f1, f2) VALUES (3, 'c'), (4, 'd'), (5, 'e');
INSERT INTO t3 (f1, f2) VALUES (3, 'c');
INSERT INTO t1 (f1, f2) VALUES (1, 'a'), (2, 'b');
COMMIT;
connection node_1;
SELECT COUNT(*) AS expect_5 FROM t1;
expect_5
5
SELECT COUNT(*) AS expect_3 FROM t3;
expect_3
3
connection node_2;
SELECT COUNT(*) AS expect_5 FROM t1;
expect_5
5
SELECT COUNT(*) AS expect_3 FROM t3;
expect_3
3
SET GLOBAL wsrep_applier_retry_count = 0;
SET DEBUG_SYNC = 'RESET';
