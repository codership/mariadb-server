#
# Test retrying applying of a transaction
#

--source include/galera_cluster.inc
--source include/have_innodb.inc

#
# Slave retries applying of a transaction multiple times. All retry attempts fail,
# and the applying will fail with the expected error.
#

CREATE TABLE t2 (f1 INTEGER PRIMARY KEY DEFAULT 0, f2 char(12));

--connection node_2
SET GLOBAL wsrep_applier_retry_count = 2;
SET GLOBAL debug_dbug = "+d,innodb_insert_fail:o,/dev/null";
CALL mtr.add_suppression("WSREP: Event 3 Write_rows_v1 apply failed: 146");
CALL mtr.add_suppression("WSREP: Inconsistency detected");
CALL mtr.add_suppression("WSREP: Failed to apply write set");

--connection node_1
SLEEP 1; 
START TRANSACTION;
INSERT INTO t2 (f1, f2) VALUES (1, 'a'), (2, 'b');
COMMIT;

SELECT COUNT(*) AS expect_2 FROM t2;

#
# Cleanup
#

SET GLOBAL wsrep_applier_retry_count = 0;
SET DEBUG_SYNC = 'RESET';
SET GLOBAL debug_dbug = DEFAULT;
DROP TABLE t2;

--source include/galera_end.inc
